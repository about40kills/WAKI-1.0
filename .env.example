# WAKI — Environment Variables
# Copy this file to .env and fill in your keys before running the app.
# NEVER commit .env to git.

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxx

# Khaya API key (GhanaNLP) — apply at https://ghananlp.org
KHAYA_API_KEY=xxxx
